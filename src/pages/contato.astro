---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <div class="flex min-h-svh w-full flex-col items-center justify-center">
    <Header />
    <main class="flex w-full flex-col items-center py-12">
      <div class="w-full max-w-6xl px-6 xl:w-4/6">
        <h1 class="mb-8 text-4xl font-bold text-primary">Contato</h1>
        <div class="mb-8">
          <div class="bg-base-100 border border-base-300 rounded-lg p-6 grid gap-4 sm:grid-cols-2">
            <a
              href="https://api.whatsapp.com/send/?phone=5551980267688"
              target="_blank"
              rel="noreferrer"
              class="flex items-center gap-3 rounded-lg border border-base-200 bg-base-200/50 p-4 transition hover:border-primary hover:bg-primary/5"
            >
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary">
                <!-- phone icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M2.5 5.5c0-1.1.9-2 2-2H7l1.4 3.5-2 1c.9 1.8 2.3 3.3 4.1 4.1l1-2L15 13v2.5c0 1.1-.9 2-2 2-.7 0-1.4-.1-2-.3-3.9-1.2-7-4.3-8.2-8.2-.2-.6-.3-1.3-.3-2Z" />
                </svg>
              </span>
              <div>
                <div class="text-sm font-semibold text-primary">WhatsApp</div>
                <div class="text-lg font-bold">051 98026-7688</div>
              </div>
            </a>
            <a
              href="https://instagram.com/azambujabehringbjj"
              target="_blank"
              rel="noreferrer"
              class="flex items-center gap-3 rounded-lg border border-base-200 bg-base-200/50 p-4 transition hover:border-primary hover:bg-primary/5"
            >
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary">
                <!-- instagram icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <rect x="4" y="4" width="16" height="16" rx="4" ry="4" stroke-width="1.75"></rect>
                  <circle cx="12" cy="12" r="3.25" stroke-width="1.75"></circle>
                  <circle cx="16.5" cy="7.5" r="0.75" fill="currentColor"></circle>
                </svg>
              </span>
              <div>
                <div class="text-sm font-semibold text-primary">Instagram</div>
                <div class="text-lg font-bold">@azambujabehringbjj</div>
              </div>
            </a>
          </div>
        </div>
        <div class="mb-8">
          <div class="bg-base-100 border-base-300 border rounded-lg p-6 w-full">
            <h2 class="mb-6 text-2xl font-semibold">Endereço</h2>
            <div class="mb-6">
              <p class="text-lg leading-relaxed">
                <strong>Escola de Jiu-Jitsu Azambuja-Behring</strong><br />
                Av. Osvaldo Aranha, 794 - Bom Fim<br />
                Porto Alegre - RS<br />
                CEP: 90035-191
              </p>
            </div>
            <div class="w-full">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3454.1069427636658!2d-51.21689218712032!3d-30.033789630681063!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95197972651a453b%3A0x1195870ed3ae9c84!2sEscola%20de%20Jiu-Jitsu%20Azambuja-Behring!5e0!3m2!1spt-BR!2sbr!4v1736881101041!5m2!1spt-BR!2sbr"
                class="h-96 w-full rounded-xl"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Google maps mostrando o endereço Av. Osvaldo Aranha, 794 - Bom Fim, Porto Alegre - RS, 90035-191."
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>
