---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Tabela from "../components/Tabela.astro";

const gradeHorarios = "/gradehorarios.jpeg";
---

<Layout>
  <div class="flex min-h-svh w-full flex-col items-center justify-center">
    <Header />
    <main class="flex w-full flex-col items-center py-12">
      <div class="w-full max-w-6xl px-6 xl:w-4/6">
        <h1 class="text-primary mb-8 text-4xl font-bold">Horários de Aulas</h1>
        <div class="mb-6 flex flex-wrap gap-3">
          <a
            class="btn btn-primary btn-sm"
            href={gradeHorarios}
            download="grade-horarios-azambuja.jpeg"
          >
            Baixar grade
          </a>
          <a
            class="btn btn-ghost btn-sm"
            href={gradeHorarios}
            target="_blank"
            rel="noreferrer"
          >
            Ver grade (imagem)
          </a>
        </div>
        <div class="mb-8">
          <Tabela />
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>
