---
import Logo from "@/components/Logo.astro";
---

<footer class="w-full bg-base-200 text-base-content">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-4 px-4 py-4">
    <div class="grid gap-4 md:grid-cols-3 md:items-start">
      <div class="flex flex-col items-center text-center gap-1">
        <Logo className="h-20 w-20" loading="lazy" />
        <p class="font-bold">Escola de Jiu-Jitsu Azambuja-Behring</p>
        <p class="text-sm opacity-80">Há 17 anos ensinando a arte suave.</p>
      </div>

      <div class="flex flex-col gap-1 text-center md:text-left">
        <h3 class="text-base font-semibold text-slate-700">Links</h3>
        <a
          class="link-hover link"
          href="https://pay.hotmart.com/W102120628U"
          data-umami-event="a-curso-didatica"
        >
          Curso A Didática
        </a>
        <a
          class="link-hover link"
          href="https://hotmart.com/pt-br/marketplace/produtos/plataforma-az/Q74306064E"
          data-umami-event="a-curso-az"
        >
          Curso AZ
        </a>
        <a class="link-hover link" href="https://sbajj.com/">
          Sylvio Behring Association (SBA)
        </a>
      </div>

      <div class="flex flex-col items-center gap-1 md:items-start">
        <h3 class="text-base font-semibold text-slate-700">Social</h3>
        <div class="flex gap-4">
          <a
            href="https://www.youtube.com/@azambujabehring8844"
            aria-label="Link para canal no YouTube."
            data-umami-event="a-youtube"
            class="text-base-content/80 transition hover:text-primary"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              class="fill-current"
            >
              <path
                d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/azambujabehringbjj/"
            aria-label="Link para página no Instagram."
            data-umami-event="a-instagram"
            class="text-base-content/80 transition hover:text-primary"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              class="fill-current"
            >
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-base-300 pt-2 text-center">
      <p class="text-sm opacity-80">
        Copyright © 2025 Escola de Jiu-Jitsu Azambuja-Behring – Todos os direitos reservados.
      </p>
    </div>
  </div>

  <!-- Botão flutuante WhatsApp -->
  <a
    href="https://api.whatsapp.com/send/?phone=5551980267688"
    target="_blank"
    rel="noreferrer"
    class="btn btn-success btn-circle fixed bottom-5 right-5 z-50 shadow-lg"
    aria-label="Atendimento via WhatsApp"
    data-umami-event="btn-whatsapp-flutuante"
  >
    <!-- Ícone WhatsApp -->
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 32 32" fill="currentColor">
      <path
        d="M16 3C9.4 3 4 8.4 4 15c0 2.5.7 4.8 2 6.8L4 29l7.4-2c1.9 1 4 1.6 6.6 1.6 6.6 0 12-5.4 12-12S22.6 3 16 3Zm0 22c-2.2 0-4.2-.6-5.9-1.7l-.4-.2-4.4 1.2 1.2-4.3-.3-.4C5 18.8 4.5 17 4.5 15 4.5 9.7 9.1 5 16 5c6.4 0 11.5 5.1 11.5 11.5S22.4 25 16 25Zm6.2-6.8c-.3-.1-1.9-.9-2.1-1s-.5-.1-.7.1c-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.1-1.3-.5-2.5-1.6-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.6c.1-.1.2-.3.2-.5s-.1-.3-.1-.4c0-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.4s1.1 2.8 1.2 3c.1.2 2.2 3.4 5.3 4.7.7.3 1.3.5 1.7.6.7.2 1.3.2 1.8.1.6-.1 1.9-.8 2.1-1.5.2-.7.2-1.3.2-1.4 0-.1-.1-.2-.3-.3Z"
      />
    </svg>
  </a>
</footer>
